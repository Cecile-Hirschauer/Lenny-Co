classDiagram
  direction TB

  namespace Domain {
    class Experience {
      <<value object>>
      +Int points
      +add(Int) Experience
    }
    class BadgeId {
      <<value object>>
      +UUID value
    }
    class LevelThreshold {
      <<value object>>
      +Int minXP
      +Int maxXP
    }
    class BadgeType {
      <<enumeration>>
      EXPLORER
      CHAMPION
      ASSIDU
      PREMIER_PAS
      SANS_FAUTE
    }
    class Player {
      <<aggregate root>>
      +UUID id
      +UUID childId
      +Experience xp
      +Level currentLevel
      +List~Badge~ badges
      +awardXP(Int)
      +evaluateBadges(BadgeEvaluator)
    }
    class Badge {
      <<entity>>
      +BadgeId id
      +BadgeType type
      +String name
      +String description
      +DateTime unlockedAt
    }
    class Level {
      <<entity>>
      +Int number
      +String name
      +LevelThreshold threshold
    }
    class PlayerRepository {
      <<interface>>
      +save(Player) Player
      +findByChild(UUID) Player?
    }
    class BadgeCatalogRepository {
      <<interface>>
      +findAll() List~Badge~
      +findByType(BadgeType) Badge?
    }
    class LevelCalculator {
      <<domain service>>
      +computeLevel(Experience) Level
    }
    class BadgeEvaluator {
      <<domain service>>
      +evaluate(Player, ActivityContext) List~Badge~
    }
    class BadgeUnlocked {
      <<domain event>>
      +UUID childId
      +Badge badge
    }
    class LevelUp {
      <<domain event>>
      +UUID childId
      +Level oldLevel
      +Level newLevel
    }
    class XPGained {
      <<domain event>>
      +UUID childId
      +Int amount
      +Experience newTotal
    }
  }

  namespace Application {
    class AwardXPCommand {
      <<command>>
      +String childId
      +Int amount
      +String reason
    }
    class EvaluateBadgesCommand {
      <<command>>
      +String childId
    }
    class GetPlayerProfileQuery {
      <<query>>
      +String childId
    }
    class AwardXPHandler {
      <<handler>>
      -PlayerRepository repository
      -LevelCalculator calculator
      -EventPublisher publisher
      +handle(AwardXPCommand)
    }
    class GetPlayerProfileHandler {
      <<handler>>
      -PlayerRepository repository
      +handle(GetPlayerProfileQuery) PlayerDTO
    }
    class PlayerDTO {
      <<dto>>
      +String childId
      +Int xp
      +Int level
      +String levelName
      +List~BadgeDTO~ badges
    }
    class BadgeDTO {
      <<dto>>
      +String id
      +String type
      +String name
      +String unlockedAt
    }
  }

  namespace Infrastructure {
    class AchievementRoutes {
      <<http routes>>
      +GET /players/childId
      +GET /badges/childId
    }
    class PlayerTable {
      <<exposed table>>
      +uuid id PK
      +uuid child_id FK
      +integer xp
      +integer level
    }
    class BadgeTable {
      <<exposed table>>
      +uuid id PK
      +uuid player_id FK
      +varchar type
      +varchar name
      +timestamp unlocked_at
    }
    class ExposedPlayerRepository {
      <<adapter>>
    }
  }

  Player "1" *-- "*" Badge
  Player "1" --> "1" Level
  Player --> Experience
  Badge --> BadgeType
  Level --> LevelThreshold

  AwardXPHandler --> PlayerRepository
  AwardXPHandler --> LevelCalculator
  GetPlayerProfileHandler --> PlayerRepository
  ExposedPlayerRepository ..|> PlayerRepository : implements
  AchievementRoutes --> AwardXPHandler
  AchievementRoutes --> GetPlayerProfileHandler

%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#3B82F6', 'primaryTextColor': '#1E293B', 'primaryBorderColor': '#2563EB', 'lineColor': '#64748B'}}}%%

flowchart TB
    subgraph TITLE["📚 MODULE APPRENTISSAGE - Architecture Hexagonale"]
        direction TB
        
        subgraph PRIMARY_ADAPTERS["🎯 Adaptateurs Primaires"]
            direction LR
            CHILD_APP["📱 App Enfant<br/>(React Native)"]
            PARENT_DASH["🖥️ Dashboard Parent<br/>(Next.js)"]
            API["🌐 API REST"]
        end
        
        subgraph PRIMARY_PORTS["📥 Ports Primaires"]
            direction LR
            PORT_MISSION["IMissionUseCase<br/>• getAvailable(childId)<br/>• start(missionId)<br/>• complete(missionId)"]
            PORT_EXERCISE["IExerciseUseCase<br/>• getByMission(missionId)<br/>• submit(result)"]
            PORT_PROGRESS["IProgressUseCase<br/>• getProgress(childId)<br/>• getHistory(childId)"]
        end
        
        subgraph APPLICATION["⚙️ Couche Application"]
            direction TB
            subgraph COMMANDS["Commands"]
                CMD1["StartMissionCommand"]
                CMD2["SubmitExerciseResultCommand"]
                CMD3["UpdateProgressCommand"]
            end
            subgraph QUERIES["Queries"]
                QRY1["GetAvailableMissionsQuery"]
                QRY2["GetMissionProgressQuery"]
                QRY3["GetExercisesByMissionQuery"]
            end
            subgraph HANDLERS["Handlers"]
                HDL1["StartMissionHandler"]
                HDL2["SubmitResultHandler"]
                HDL3["ProgressCalculationHandler"]
            end
        end
        
        subgraph DOMAIN["💎 Couche Domaine"]
            direction TB
            subgraph ENTITIES["Entités"]
                E_MISSION["📦 Mission<br/>─────────<br/>id: MissionId<br/>title: string<br/>description: string<br/>difficulty: DifficultyLevel<br/>exercises: Exercise[]<br/>estimatedTime: Duration"]
                E_EXERCISE["📦 Exercise<br/>─────────<br/>id: ExerciseId<br/>type: ExerciseType<br/>content: Content<br/>correctAnswer: Answer<br/>hints: Hint[]"]
                E_CONTENT["📦 Content<br/>─────────<br/>text: string<br/>audioUrl?: string<br/>imageUrl?: string<br/>adaptedVersion?: AdaptedContent"]
            end
            subgraph AGGREGATES["Agrégats"]
                AGG_PROGRESS["🔷 Progress (Agrégat Racine)<br/>─────────<br/>id: ProgressId<br/>childId: ProfileId<br/>missionId: MissionId<br/>completionRate: number<br/>totalScore: number<br/>timeSpent: Duration<br/>exerciseResults: ExerciseResult[]<br/>─────────<br/>addResult(result)<br/>recalculateMetrics()<br/>detectRecurrentErrors()"]
                AGG_SESSION["🔷 LearningSession<br/>─────────<br/>id: SessionId<br/>startedAt: Date<br/>exercises: Exercise[]<br/>currentIndex: number"]
            end
            subgraph VALUE_OBJECTS["Value Objects"]
                VO_SCORE["💎 Score<br/>0-100"]
                VO_ERROR["💎 ErrorType<br/>CONFUSION_BD<br/>CONFUSION_PQ<br/>INVERSION<br/>OMISSION"]
                VO_DIFF["💎 DifficultyLevel<br/>EASY | MEDIUM | HARD"]
            end
            subgraph DOMAIN_SERVICES["Services Domaine"]
                SVC_PROGRESS["🔧 ProgressCalculationService<br/>─────────<br/>calculate(results)"]
                SVC_ERROR["🔧 ErrorDetectionService<br/>─────────<br/>detect(answer, expected)<br/>categorize(errors)"]
            end
            subgraph DOMAIN_EVENTS["Événements Domaine"]
                EVT1["📨 MissionStarted"]
                EVT2["📨 ExerciseCompleted"]
                EVT3["📨 ProgressUpdated"]
                EVT4["📨 ErrorDetected"]
            end
        end
        
        subgraph SECONDARY_PORTS["📤 Ports Secondaires"]
            direction LR
            PORT_MISSION_REPO["IMissionRepository<br/>• findById(id)<br/>• findByDifficulty(level)<br/>• findAvailable(childId)"]
            PORT_PROGRESS_REPO["IProgressRepository<br/>• findByChild(childId)<br/>• save(progress)<br/>• getHistory(childId)"]
            PORT_CONTENT["IContentProvider<br/>• getContent(contentId)<br/>• getAdapted(contentId, settings)"]
        end
        
        subgraph SECONDARY_ADAPTERS["🔌 Adaptateurs Secondaires"]
            direction LR
            SUPABASE_MISSION["🗄️ SupabaseMissionRepository"]
            SUPABASE_PROGRESS["🗄️ SupabaseProgressRepository"]
            CDN_CONTENT["🌐 ContentCDNProvider"]
        end
        
        subgraph INFRASTRUCTURE["🏗️ Infrastructure"]
            direction LR
            DB[(🐘 PostgreSQL)]
            CDN[(☁️ CDN<br/>Contenu Média)]
            STORAGE[(📁 S3<br/>Assets)]
        end
        
        subgraph EVENT_BUS["📡 Bus d'Événements"]
            BUS["Event Dispatcher"]
            SUB_GAMIF["→ Gamification Module"]
            SUB_SUPER["→ Supervision Module"]
        end
    end
    
    %% Connexions Primary
    CHILD_APP --> PORT_MISSION
    CHILD_APP --> PORT_EXERCISE
    PARENT_DASH --> PORT_PROGRESS
    API --> PORT_MISSION
    API --> PORT_EXERCISE
    API --> PORT_PROGRESS
    
    %% Connexions Application
    PORT_MISSION --> HDL1
    PORT_EXERCISE --> HDL2
    PORT_PROGRESS --> HDL3
    
    HDL1 --> CMD1
    HDL2 --> CMD2
    HDL3 --> CMD3
    
    %% Connexions Domain
    HDL1 --> E_MISSION
    HDL2 --> AGG_PROGRESS
    HDL3 --> AGG_PROGRESS
    
    E_MISSION --> E_EXERCISE
    E_EXERCISE --> E_CONTENT
    AGG_PROGRESS --> VO_SCORE
    AGG_PROGRESS --> VO_ERROR
    
    HDL2 --> SVC_ERROR
    HDL3 --> SVC_PROGRESS
    
    SVC_ERROR -.-> EVT4
    HDL1 -.-> EVT1
    HDL2 -.-> EVT2
    HDL3 -.-> EVT3
    
    %% Connexions Secondary
    HDL1 --> PORT_MISSION_REPO
    HDL2 --> PORT_PROGRESS_REPO
    HDL2 --> PORT_CONTENT
    
    PORT_MISSION_REPO --> SUPABASE_MISSION
    PORT_PROGRESS_REPO --> SUPABASE_PROGRESS
    PORT_CONTENT --> CDN_CONTENT
    
    SUPABASE_MISSION --> DB
    SUPABASE_PROGRESS --> DB
    CDN_CONTENT --> CDN
    CDN_CONTENT --> STORAGE
    
    %% Event Bus
    EVT2 --> BUS
    EVT3 --> BUS
    EVT4 --> BUS
    BUS --> SUB_GAMIF
    BUS --> SUB_SUPER
    
    %% Styles
    classDef primary fill:#3B82F6,stroke:#2563EB,color:#fff
    classDef port fill:#8B5CF6,stroke:#7C3AED,color:#fff
    classDef application fill:#F59E0B,stroke:#D97706,color:#fff
    classDef domain fill:#10B981,stroke:#059669,color:#fff
    classDef aggregate fill:#EC4899,stroke:#DB2777,color:#fff
    classDef secondary fill:#6366F1,stroke:#4F46E5,color:#fff
    classDef infra fill:#64748B,stroke:#475569,color:#fff
    classDef event fill:#EF4444,stroke:#DC2626,color:#fff
    
    class CHILD_APP,PARENT_DASH,API primary
    class PORT_MISSION,PORT_EXERCISE,PORT_PROGRESS,PORT_MISSION_REPO,PORT_PROGRESS_REPO,PORT_CONTENT port
    class CMD1,CMD2,CMD3,QRY1,QRY2,QRY3,HDL1,HDL2,HDL3 application
    class E_MISSION,E_EXERCISE,E_CONTENT,VO_SCORE,VO_ERROR,VO_DIFF,SVC_PROGRESS,SVC_ERROR domain
    class AGG_PROGRESS,AGG_SESSION aggregate
    class SUPABASE_MISSION,SUPABASE_PROGRESS,CDN_CONTENT secondary
    class DB,CDN,STORAGE infra
    class EVT1,EVT2,EVT3,EVT4,BUS,SUB_GAMIF,SUB_SUPER event

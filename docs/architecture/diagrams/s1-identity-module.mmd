classDiagram
  direction TB

  namespace Domain {
    class UserId {
      <<value object>>
      +UUID value
    }
    class Email {
      <<value object>>
      +String value
      +validate()
    }
    class Password {
      <<value object>>
      +String hash
    }
    class ProfileType {
      <<enumeration>>
      PARENT
      CHILD
      THERAPIST
      TEACHER
    }
    class RelationType {
      <<enumeration>>
      PARENTAL
      THERAPEUTIC
      EDUCATIONAL
    }
    class RelationStatus {
      <<enumeration>>
      PENDING
      ACTIVE
      SUSPENDED
      REVOKED
    }
    class Action {
      <<enumeration>>
      READ
      WRITE
      SEND_MESSAGE
      GENERATE_REPORT
      WRITE_CLINICAL_NOTE
      MODIFY_ADAPTIVE_CONFIG
      MANAGE_PROFILE
    }
    class ResourceType {
      <<enumeration>>
      DASHBOARD
      PROGRESS_SUMMARY
      PROGRESS_DETAIL
      ALERT
      MESSAGE
      ACHIEVEMENT
      WEEKLY_REPORT
      CLINICAL_NOTE
      ADAPTIVE_CONFIG
      CHILD_PROFILE
    }
    class Constraint {
      <<enumeration>>
      OWN_CHILDREN_ONLY
      LINKED_PATIENTS_ONLY
      LINKED_STUDENTS_ONLY
      AGGREGATED_ONLY
    }
    class Permission {
      <<value object>>
      +Action action
      +ResourceType resourceType
      +Constraint? constraint
    }
    class ParentAccount {
      <<aggregate root>>
      +UserId id
      +Email email
      +String firstName
      +String lastName
      +Password password
      +ProfileType profileType
      +List~ChildProfile~ children
      +addChild(name, age) ChildProfile
      +create(email, firstName, lastName, hash)$ ParentAccount
    }
    class ChildProfile {
      <<entity>>
      +UserId id
      +String name
      +Int age
      +UserId parentId
    }
    class CareRelation {
      <<aggregate root>>
      +UUID id
      +UserId observerId
      +UserId observeeId
      +RelationType relationType
      +RelationStatus status
      +DateTime grantedAt
      +DateTime? revokedAt
      +UserId grantedBy
      +activate()
      +revoke()
      +suspend()
      +isActive() Boolean
    }
    class AccountRepository {
      <<interface>>
      +save(ParentAccount) ParentAccount
      +findByEmail(Email) ParentAccount?
      +findById(UserId) ParentAccount?
      +existsByEmail(Email) Boolean
    }
    class CareRelationRepository {
      <<interface>>
      +save(CareRelation) CareRelation
      +findActiveByObserverAndObservee(UserId, UserId) CareRelation?
      +findActiveByObserver(UserId) List~CareRelation~
      +findActiveByObservee(UserId) List~CareRelation~
    }
    class AuthDomainService {
      <<domain service>>
      +validateCredentials(Email, Password) Boolean
    }
    class CareRelationLifecycle {
      <<domain service>>
      +establish(observerId, observeeId, type, grantedBy) CareRelation
      +revoke(CareRelation)
      +suspend(CareRelation)
      +validateInvitation(parentId, inviteeId, type) Boolean
    }
    class AccountCreated {
      <<domain event>>
      +UserId accountId
      +Email email
      +ProfileType profileType
    }
    class ChildProfileAdded {
      <<domain event>>
      +UserId parentId
      +UserId childId
      +String childName
    }
    class CareRelationEstablished {
      <<domain event>>
      +UUID relationId
      +UserId observerId
      +UserId observeeId
      +RelationType type
    }
    class CareRelationRevoked {
      <<domain event>>
      +UUID relationId
      +UserId observerId
      +UserId observeeId
      +DateTime revokedAt
    }
  }

  namespace Application {
    class RegisterParentCommand {
      <<command>>
      +String email
      +String firstName
      +String lastName
      +String password
    }
    class LoginCommand {
      <<command>>
      +String email
      +String password
    }
    class AddChildCommand {
      <<command>>
      +UserId parentId
      +String name
      +Int age
    }
    class InviteTherapistCommand {
      <<command>>
      +UserId parentId
      +UserId childId
      +String therapistEmail
    }
    class AcceptInvitationCommand {
      <<command>>
      +UUID relationId
      +UserId therapistId
    }
    class ConfirmRelationCommand {
      <<command>>
      +UUID relationId
      +UserId parentId
    }
    class RevokeRelationCommand {
      <<command>>
      +UUID relationId
      +UserId requestedBy
    }
    class GetCurrentUserQuery {
      <<query>>
      +UserId userId
    }
    class GetChildrenQuery {
      <<query>>
      +UserId parentId
    }
    class GetCareRelationsQuery {
      <<query>>
      +UserId userId
    }
    class RegisterParentHandler {
      <<handler>>
      -AccountRepository repository
      -PasswordHasher hasher
      -EventPublisher publisher
      +handle(RegisterParentCommand) ParentAccountDTO
    }
    class LoginHandler {
      <<handler>>
      -AccountRepository repository
      -PasswordHasher hasher
      -TokenProvider tokens
      +handle(LoginCommand) AuthTokenDTO
    }
    class InviteTherapistHandler {
      <<handler>>
      -CareRelationRepository relations
      -CareRelationLifecycle lifecycle
      -EventPublisher publisher
      +handle(InviteTherapistCommand)
    }
    class RevokeRelationHandler {
      <<handler>>
      -CareRelationRepository relations
      -CareRelationLifecycle lifecycle
      -EventPublisher publisher
      +handle(RevokeRelationCommand)
    }
    class ParentAccountDTO {
      <<dto>>
      +String id
      +String email
      +String firstName
      +String lastName
      +String profileType
    }
    class ChildProfileDTO {
      <<dto>>
      +String id
      +String name
      +Int age
    }
    class AuthTokenDTO {
      <<dto>>
      +String accessToken
      +String refreshToken
      +Long expiresIn
    }
    class CareRelationDTO {
      <<dto>>
      +String id
      +String observerId
      +String observeeId
      +String relationType
      +String status
    }
    class PasswordHasher {
      <<port>>
      +hash(String) String
      +verify(String, String) Boolean
    }
    class TokenProvider {
      <<port>>
      +generate(UserId, ProfileType) String
      +validate(String) UserId?
    }
  }

  namespace Infrastructure {
    class AuthRoutes {
      <<http routes>>
      +POST /auth/register
      +POST /auth/login
      +GET /users/me
      +GET /users/me/children
      +POST /relations/invite
      +POST /relations/id/accept
      +POST /relations/id/confirm
      +DELETE /relations/id
    }
    class AccountTable {
      <<exposed table>>
      +uuid id PK
      +varchar email UNIQUE
      +varchar first_name
      +varchar last_name
      +varchar password_hash
      +varchar profile_type
    }
    class ChildProfileTable {
      <<exposed table>>
      +uuid id PK
      +varchar name
      +integer age
      +uuid parent_id FK
    }
    class CareRelationTable {
      <<exposed table>>
      +uuid id PK
      +uuid observer_id FK
      +uuid observee_id FK
      +varchar relation_type
      +varchar status
      +timestamp granted_at
      +timestamp revoked_at
      +uuid granted_by FK
    }
    class ExposedAccountRepository {
      <<adapter>>
    }
    class ExposedCareRelationRepository {
      <<adapter>>
    }
    class BCryptPasswordHasher {
      <<adapter>>
    }
    class JwtTokenProvider {
      <<adapter>>
    }
  }

  ParentAccount "1" *-- "0..5" ChildProfile
  ParentAccount --> UserId
  ParentAccount --> Email
  ParentAccount --> Password
  ParentAccount --> ProfileType
  ChildProfile --> UserId
  CareRelation --> UserId
  CareRelation --> RelationType
  CareRelation --> RelationStatus
  Permission --> Action
  Permission --> ResourceType
  Permission --> Constraint

  RegisterParentHandler --> AccountRepository
  RegisterParentHandler --> PasswordHasher
  LoginHandler --> AccountRepository
  LoginHandler --> TokenProvider
  InviteTherapistHandler --> CareRelationRepository
  InviteTherapistHandler --> CareRelationLifecycle
  RevokeRelationHandler --> CareRelationRepository

  ExposedAccountRepository ..|> AccountRepository : implements
  ExposedCareRelationRepository ..|> CareRelationRepository : implements
  BCryptPasswordHasher ..|> PasswordHasher : implements
  JwtTokenProvider ..|> TokenProvider : implements
  AuthRoutes --> RegisterParentHandler
  AuthRoutes --> LoginHandler
  AuthRoutes --> InviteTherapistHandler
  AuthRoutes --> RevokeRelationHandler

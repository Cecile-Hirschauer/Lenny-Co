graph TB
  REQ["Requête HTTP entrante
  JWT Bearer Token"] --> MW["Niveau 1 : PolicyEnforcerMiddleware
  ───────────
  Extrait UserId + ProfileType du JWT
  Construit AccessScope
  Appelle PolicyEvaluator
  ───────────
  Si DENIED → HTTP 403
  Si GRANTED → continue"]

  MW -->|GRANTED| HANDLER["Handler
  (use case)"]

  HANDLER --> RLS["Niveau 2 : PostgreSQL RLS
  ───────────
  Policy sur chaque table :
  child_id IN (
    SELECT observee_id
    FROM care_relations
    WHERE observer_id = current_user_id
    AND status = ACTIVE
  )
  ───────────
  Même si le code a un bug,
  la BDD refuse les lignes
  non autorisées"]

  RLS --> DATA["Données retournées"]

  MW -->|DENIED| BLOCK["HTTP 403 Forbidden
  + AccessAuditLog enregistré"]

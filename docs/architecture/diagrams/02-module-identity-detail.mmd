%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#3B82F6', 'primaryTextColor': '#1E293B', 'primaryBorderColor': '#2563EB', 'lineColor': '#64748B', 'secondaryColor': '#FF9500', 'tertiaryColor': '#1ABFB4', 'background': '#F8FAFC'}}}%%

flowchart TB
    subgraph TITLE["🔐 MODULE IDENTITÉ & ACCÈS - Architecture Hexagonale"]
        direction TB
        
        subgraph PRIMARY_ADAPTERS["🎯 Adaptateurs Primaires (Driving)"]
            direction LR
            WEB_UI["🖥️ Interface Web<br/>(Next.js Pages)"]
            MOBILE_UI["📱 Interface Mobile<br/>(React Native)"]
            API_REST["🌐 API REST<br/>(Routes Next.js)"]
        end
        
        subgraph PRIMARY_PORTS["📥 Ports Primaires (Use Cases)"]
            direction LR
            PORT_AUTH["IAuthenticationUseCase<br/>• login(email, password)<br/>• logout(sessionId)<br/>• validateSession(token)"]
            PORT_REG["IRegistrationUseCase<br/>• register(data)<br/>• verifyEmail(token)"]
        end
        
        subgraph APPLICATION["⚙️ Couche Application"]
            direction TB
            subgraph COMMANDS["Commands"]
                CMD1["RegisterUserCommand"]
                CMD2["LoginCommand"]
                CMD3["LogoutCommand"]
                CMD4["ResetPasswordCommand"]
            end
            subgraph QUERIES["Queries"]
                QRY1["GetCurrentUserQuery"]
                QRY2["ValidateSessionQuery"]
            end
            subgraph HANDLERS["Handlers"]
                HDL1["RegisterUserHandler"]
                HDL2["LoginHandler"]
                HDL3["LogoutHandler"]
            end
        end
        
        subgraph DOMAIN["💎 Couche Domaine (Cœur Métier)"]
            direction TB
            subgraph ENTITIES["Entités"]
                E_USER["📦 User<br/>─────────<br/>id: UserId<br/>email: Email<br/>firstName: string<br/>lastName: string<br/>role: Role<br/>createdAt: Date"]
                E_CRED["📦 Credentials<br/>─────────<br/>userId: UserId<br/>passwordHash: string<br/>lastChanged: Date"]
                E_SESS["📦 Session<br/>─────────<br/>id: SessionId<br/>userId: UserId<br/>token: string<br/>expiresAt: Date"]
            end
            subgraph VALUE_OBJECTS["Value Objects"]
                VO_EMAIL["💎 Email<br/>─────────<br/>validate()<br/>normalize()"]
                VO_PWD["💎 Password<br/>─────────<br/>validate()<br/>checkStrength()"]
                VO_ROLE["💎 Role<br/>─────────<br/>parent | child<br/>admin | therapist"]
                VO_UID["💎 UserId<br/>─────────<br/>generate()<br/>validate()"]
            end
            subgraph DOMAIN_SERVICES["Services Domaine"]
                SVC_HASH["🔧 PasswordHashingService<br/>─────────<br/>hash(password)<br/>verify(password, hash)"]
            end
            subgraph DOMAIN_EVENTS["Événements Domaine"]
                EVT1["📨 UserRegistered"]
                EVT2["📨 UserLoggedIn"]
                EVT3["📨 UserLoggedOut"]
                EVT4["📨 PasswordReset"]
            end
        end
        
        subgraph SECONDARY_PORTS["📤 Ports Secondaires (Interfaces)"]
            direction LR
            PORT_USER_REPO["IUserRepository<br/>• findById(id)<br/>• findByEmail(email)<br/>• save(user)<br/>• delete(id)"]
            PORT_SESS_REPO["ISessionRepository<br/>• create(session)<br/>• findByToken(token)<br/>• invalidate(id)"]
            PORT_HASHER["IPasswordHasher<br/>• hash(password)<br/>• verify(pwd, hash)"]
        end
        
        subgraph SECONDARY_ADAPTERS["🔌 Adaptateurs Secondaires (Driven)"]
            direction LR
            SUPABASE_USER["🗄️ SupabaseUserRepository<br/>(PostgreSQL)"]
            SUPABASE_SESS["🗄️ SupabaseSessionRepository<br/>(PostgreSQL)"]
            BCRYPT["🔐 BcryptPasswordHasher"]
        end
        
        subgraph INFRASTRUCTURE["🏗️ Infrastructure"]
            direction LR
            DB[(🐘 PostgreSQL<br/>Supabase)]
            CACHE[(⚡ Redis<br/>Sessions)]
        end
    end
    
    %% Connexions Primary
    WEB_UI --> PORT_AUTH
    WEB_UI --> PORT_REG
    MOBILE_UI --> PORT_AUTH
    MOBILE_UI --> PORT_REG
    API_REST --> PORT_AUTH
    API_REST --> PORT_REG
    
    %% Connexions Application
    PORT_AUTH --> HDL2
    PORT_AUTH --> HDL3
    PORT_REG --> HDL1
    
    HDL1 --> CMD1
    HDL2 --> CMD2
    HDL3 --> CMD3
    
    %% Connexions Domain
    HDL1 --> E_USER
    HDL2 --> E_SESS
    HDL3 --> E_SESS
    
    E_USER --> VO_EMAIL
    E_USER --> VO_ROLE
    E_USER --> VO_UID
    E_CRED --> VO_PWD
    
    HDL1 --> SVC_HASH
    HDL2 --> SVC_HASH
    
    HDL1 -.-> EVT1
    HDL2 -.-> EVT2
    HDL3 -.-> EVT3
    
    %% Connexions Secondary
    HDL1 --> PORT_USER_REPO
    HDL2 --> PORT_USER_REPO
    HDL2 --> PORT_SESS_REPO
    HDL3 --> PORT_SESS_REPO
    SVC_HASH --> PORT_HASHER
    
    PORT_USER_REPO --> SUPABASE_USER
    PORT_SESS_REPO --> SUPABASE_SESS
    PORT_HASHER --> BCRYPT
    
    SUPABASE_USER --> DB
    SUPABASE_SESS --> CACHE
    
    %% Styles
    classDef primary fill:#3B82F6,stroke:#2563EB,color:#fff
    classDef port fill:#8B5CF6,stroke:#7C3AED,color:#fff
    classDef application fill:#F59E0B,stroke:#D97706,color:#fff
    classDef domain fill:#10B981,stroke:#059669,color:#fff
    classDef secondary fill:#6366F1,stroke:#4F46E5,color:#fff
    classDef infra fill:#64748B,stroke:#475569,color:#fff
    
    class WEB_UI,MOBILE_UI,API_REST primary
    class PORT_AUTH,PORT_REG,PORT_USER_REPO,PORT_SESS_REPO,PORT_HASHER port
    class CMD1,CMD2,CMD3,CMD4,QRY1,QRY2,HDL1,HDL2,HDL3 application
    class E_USER,E_CRED,E_SESS,VO_EMAIL,VO_PWD,VO_ROLE,VO_UID,SVC_HASH,EVT1,EVT2,EVT3,EVT4 domain
    class SUPABASE_USER,SUPABASE_SESS,BCRYPT secondary
    class DB,CACHE infra
